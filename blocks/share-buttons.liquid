{%- doc -%}
  Botones de compartir (Facebook / X / Pinterest) para la página de producto.
  Comparten la URL del producto actual. Estilo Impulse: icono + etiqueta en fila.
{%- enddoc -%}

{% liquid
  assign product = closest.product
  if request.visual_preview_mode and product == blank
    assign product = collections.all.products.first
  endif

  assign share_url = shop.secure_url | append: product.url
  assign share_title = product.title | default: shop.name
  assign share_image = product.featured_image | image_url: width: 1200

  # Codificamos SOLO los valores dinámicos (no la URL base), si no el navegador
  # trata el href como un enlace relativo y devuelve "Not Found".
  assign share_url_enc = share_url | url_encode
  assign share_title_enc = share_title | url_encode

  assign fb_url = 'https://www.facebook.com/sharer/sharer.php?u=' | append: share_url_enc
  assign x_url = 'https://twitter.com/intent/tweet?text=' | append: share_title_enc | append: '&url=' | append: share_url_enc

  capture pin_url
    echo 'https://www.pinterest.com/pin/create/button/?url='
    echo share_url_enc
    echo '&description='
    echo share_title_enc
    if share_image != blank
      echo '&media='
      echo share_image | prepend: 'https:' | url_encode
    endif
  endcapture
%}

<div
  class="share-buttons spacing-style"
  style="{% render 'spacing-style', settings: block.settings %}"
  {{ block.shopify_attributes }}
>
  <a
    class="share-buttons__item"
    href="{{ fb_url }}"
    target="_blank"
    rel="noopener"
    aria-label="Compartir en Facebook"
    onclick="window.open(this.href,'share','width=600,height=520,noopener');return false;"
  >
    {% render 'icon-or-image', icon: 'facebook', width: 18, class_name: 'share-buttons__icon' %}
    <span class="share-buttons__label">Compartir</span>
  </a>

  <a
    class="share-buttons__item"
    href="{{ x_url }}"
    target="_blank"
    rel="noopener"
    aria-label="Compartir en X"
    onclick="window.open(this.href,'share','width=600,height=520,noopener');return false;"
  >
    {% render 'icon-or-image', icon: 'twitter', width: 18, class_name: 'share-buttons__icon' %}
    <span class="share-buttons__label">Compartir</span>
  </a>

  <a
    class="share-buttons__item"
    href="{{ pin_url | strip_newlines }}"
    target="_blank"
    rel="noopener"
    aria-label="Guardar en Pinterest"
    onclick="window.open(this.href,'share','width=600,height=520,noopener');return false;"
  >
    {% render 'icon-or-image', icon: 'pinterest', width: 18, class_name: 'share-buttons__icon' %}
    <span class="share-buttons__label">Pinear</span>
  </a>
</div>

{% stylesheet %}
  .share-buttons {
    display: flex;
    align-items: center;
    gap: 22px;
    flex-wrap: wrap;
  }

  .share-buttons__item {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    color: var(--color-foreground);
    text-decoration: none;
    font-size: 0.8125rem;
    letter-spacing: 0.02em;
    opacity: 0.85;
    transition: opacity 0.2s ease;
  }

  .share-buttons__item:hover {
    opacity: 1;
  }

  .share-buttons__icon {
    display: inline-block;
    width: 18px;
    height: 18px;
    color: var(--color-foreground);
    flex-shrink: 0;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Botones de compartir",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-start",
      "label": "t:settings.left",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding-inline-end",
      "label": "t:settings.right",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    }
  ]
}
{% endschema %}
