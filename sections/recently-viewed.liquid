{%- comment -%}
  Sección "Vistos recientemente" (estilo Impulse).
  El tema ya guarda los IDs de productos vistos en localStorage
  (RecentlyViewed.addProduct en snippets/scripts.liquid). Aquí:
   - En carga normal la sección va vacía y oculta.
   - El custom element recently-viewed-products (recently-viewed-init.js) lee
     esos IDs y vuelve a pedir ESTA misma sección al endpoint de búsqueda
     (?q=id:.. OR id:..&section_id=...), que la renderiza con search.results
     poblado, y luego inyecta las tarjetas.
{%- endcomment -%}

{%- liquid
  case section.settings.image_ratio
    when 'square'
      assign rv_ratio = '1 / 1'
    when 'landscape'
      assign rv_ratio = '4 / 3'
    else
      assign rv_ratio = '3 / 4'
  endcase
-%}

<recently-viewed-products
  class="recently-viewed section section--page-width"
  data-section-id="{{ section.id }}"
  {% unless search.performed and search.results.size > 0 %}hidden{% endunless %}
>
  <div class="recently-viewed__inner">
    {%- if search.performed and search.results.size > 0 -%}
      <h2 class="recently-viewed__heading">
        {{ section.settings.heading | default: 'Vistos recientemente' }}
      </h2>
      <div class="recently-viewed__grid" style="--rv-ratio: {{ rv_ratio }};">
        {%- for product in search.results limit: section.settings.max_products -%}
          <a class="rv-card" href="{{ product.url }}">
            <div class="rv-card__media">
              {%- if product.featured_image -%}
                {{
                  product.featured_image
                  | image_url: width: 600
                  | image_tag: loading: 'lazy', widths: '300, 600', class: 'rv-card__img', alt: product.title
                }}
              {%- endif -%}
            </div>
            <div class="rv-card__title">{{ product.title }}</div>
            <div class="rv-card__price">{{ product.price | money }}</div>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <script src="{{ 'recently-viewed-init.js' | asset_url }}" type="module"></script>
</recently-viewed-products>

{% stylesheet %}
  .recently-viewed {
    position: relative;
    padding-block: 48px;
  }

  /* Línea separadora full-width arriba de la sección (como Impulse) */
  .recently-viewed::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 100vw;
    border-top: 1px solid rgba(47, 41, 37, 0.12);
  }

  .recently-viewed__heading {
    margin: 0 0 24px;
    font-weight: 400;
    letter-spacing: 0.02em;
  }

  .recently-viewed__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px 24px;
  }

  .rv-card {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .rv-card__media {
    overflow: hidden;
    aspect-ratio: var(--rv-ratio, 3 / 4);
  }

  .rv-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .rv-card:hover .rv-card__img {
    transform: scale(1.03);
  }

  .rv-card__title {
    margin-top: 12px;
    font-size: 0.95rem;
    letter-spacing: 0.02em;
  }

  .rv-card__price {
    margin-top: 4px;
    font-size: 0.9rem;
    letter-spacing: 0.05em;
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {
    .recently-viewed__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Vistos recientemente",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Vistos recientemente"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Máximo de productos",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Relación de aspecto",
      "options": [
        { "value": "portrait", "label": "Vertical" },
        { "value": "square", "label": "Cuadrada" },
        { "value": "landscape", "label": "Horizontal" }
      ],
      "default": "portrait"
    }
  ],
  "presets": [
    {
      "name": "Vistos recientemente"
    }
  ]
}
{% endschema %}
